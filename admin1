<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>School Admin Portal</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f0f2f5; padding: 20px; }
        .container { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
        .box { background: white; padding: 20px; border-radius: 10px; width: 400px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        h2 { color: #333; text-align: center; }
        input, textarea { width: 90%; padding: 10px; margin: 5px 0; border: 1px solid #ddd; border-radius: 5px; }
        button { width: 95%; padding: 10px; background-color: #28a745; color: white; border: none; border-radius: 5px; cursor: pointer; margin-top: 10px; font-weight: bold; }
        button.remove { background-color: #dc3545; width: 100%; margin-top: 5px; }
        .list-item { border-bottom: 1px solid #eee; padding: 10px 0; margin-top: 10px; }
    </style>
</head>
<body>

    <h1 style="text-align: center; color: #333;">School Admin Management</h1>

    <div class="container">
        <!-- Student Section -->
        <div class="box">
            <h2>Students Detail</h2>
            <input type="text" id="sName" placeholder="Student Name">
            <input type="date" id="sDob">
            <input type="text" id="sFather" placeholder="Father Name">
            <textarea id="sAddress" placeholder="Address"></textarea>
            <input type="number" id="sMobile" placeholder="Mobile Number">
            <button onclick="addStudent()">Add Student</button>
            <div id="studentList"></div>
        </div>

        <!-- Teacher Section -->
        <div class="box">
            <h2>Teachers Detail</h2>
            <input type="text" id="tName" placeholder="Teacher Name">
            <input type="text" id="tQual" placeholder="Qualification">
            <input type="text" id="tExp" placeholder="Experience">
            <textarea id="tAddress" placeholder="Address"></textarea>
            <input type="number" id="tMobile" placeholder="Phone Number">
            <button onclick="addTeacher()">Add Teacher</button>
            <div id="teacherList"></div>
        </div>
    </div>

    <script>
        // Data Load karne ke liye
        let students = JSON.parse(localStorage.getItem('students')) || [];
        let teachers = JSON.parse(localStorage.getItem('teachers')) || [];

        function updateUI() {
            // Students ki list dikhane ke liye
            document.getElementById('studentList').innerHTML = students.map((s, i) => `
                <div class="list-item">
                    <strong>Name: ${s.name}</strong><br> 
                    DOB: ${s.dob} | Father: ${s.father} <br> 
                    Address: ${s.address} | Mob: ${s.mobile}
                    <button class="remove" onclick="removeStudent(${i})">Remove</button>
                </div>`).join('');

            // Teachers ki list dikhane ke liye
            document.getElementById('teacherList').innerHTML = teachers.map((t, i) => `
                <div class="list-item">
                    <strong>Name: ${t.name}</strong><br> 
                    Qual: ${t.qual} | Exp: ${t.exp} <br> 
                    Address: ${t.address} | Ph: ${t.mobile}
                    <button class="remove" onclick="removeTeacher(${i})">Remove</button>
                </div>`).join('');
        }

        // Student Add karne ka function
        function addStudent() {
            const name = document.getElementById('sName').value;
            const dob = document.getElementById('sDob').value;
            const father = document.getElementById('sFather').value;
            const address = document.getElementById('sAddress').value;
            const mobile = document.getElementById('sMobile').value;

            if(name && dob && father && address && mobile) {
                students.push({ name, dob, father, address, mobile });
                localStorage.setItem('students', JSON.stringify(students));
                updateUI();
                // Form clear karne ke liye
                document.getElementById('sName').value = '';
                document.getElementById('sDob').value = '';
                document.getElementById('sFather').value = '';
                document.getElementById('sAddress').value = '';
                document.getElementById('sMobile').value = '';
            } else {
                alert("Please fill all student fields!");
            }
        }

        // Teacher Add karne ka function
        function addTeacher() {
            const name = document.getElementById('tName').value;
            const qual = document.getElementById('tQual').value;
            const exp = document.getElementById('tExp').value;
            const address = document.getElementById('tAddress').value;
            const mobile = document.getElementById('tMobile').value;

            if(name && qual && exp && address && mobile) {
                teachers.push({ name, qual, exp, address, mobile });
                localStorage.setItem('teachers', JSON.stringify(teachers));
                updateUI();
                // Form clear karne ke liye
                document.getElementById('tName').value = '';
                document.getElementById('tQual').value = '';
                document.getElementById('tExp').value = '';
                document.getElementById('tAddress').value = '';
                document.getElementById('tMobile').value = '';
            } else {
                alert("Please fill all teacher fields!");
            }
        }

        // Remove karne ke functions
        function removeStudent(i) { 
            students.splice(i, 1); 
            localStorage.setItem('students', JSON.stringify(students)); 
            updateUI(); 
        }
        
        function removeTeacher(i) { 
            teachers.splice(i, 1); 
            localStorage.setItem('teachers', JSON.stringify(teachers)); 
            updateUI(); 
        }

        // Page load hote hi purana data dikhane ke liye
        updateUI();
    </script>
</body>
</html>

